{
  "name": "ThingP2PSDK",
  "version": "3.13.1",
  "summary": "open SDK code for tuya p2p.",
  "homepage": "https://github.com/tuya",
  "license": "none",
  "authors": {
    "TuyaInc": "https://developer.tuya.com/"
  },
  "source": {
    "http": "https://images.tuyacn.com/smart/app/package/pods/ios/ThingP2PSDK-3.13.1-987d42.zip",
    "type": "zip",
    "sha1": "aabd8434d2c4cf55bacfd8d706a834f0700bd273"
  },
  "platforms": {
    "ios": "9.0"
  },
  "exclude_files": [
    "ThingP2PSDK/libs/Android/*",
    "ThingP2PSDK/Platforms/Android/*",
    "sts/src/webrtc/*",
    "sts/src/connection/sts_webrtc_connection.c"
  ],
  "ios": {
  },
  "dependencies": {
    "ThingMbedtls": [

    ],
    "ThingAvLoggerSDK": [

    ]
  },
  "libraries": [
    "c++",
    "z",
    "iconv",
    "bz2",
    "resolv"
  ],
  "frameworks": [
    "Foundation",
    "AVFoundation",
    "CoreAudio",
    "CoreMedia",
    "CoreVideo",
    "VideoToolbox"
  ],
  "pod_target_xcconfig": {
    "OTHER_CFLAGS": "-DLINUX",
    "GCC_PREPROCESSOR_DEFINITIONS": "WEBRTC_POSIX HAVE_STRLCPY STS_ENABLE_P2P STS_ENABLE_MEM_ANALYZE STS_ENABLE_ICE STS_ENABLE_RELAY STS_ENABLE_STATS_COLLECTOR STS_ENABLE_MEDIA_CHANNEL STS_ENABLE_RELIABLE_CHANNEL STS_ENABLE_UNRELIABLE_CHANNEL STS_ENABLE_TRANSPORT_CHANNEL STS_ENABLE_CC  $(inherited)",
    "HEADER_SEARCH_PATHS": "$(PODS_TARGET_SRCROOT)/ThingP2PSDK $(PODS_TARGET_SRCROOT)/ThingP2PSDK/Platforms/iOS $(PODS_TARGET_SRCROOT)/ThingP2PSDK/Utils $(PODS_TARGET_SRCROOT)/ThingP2PSDK/LogManager $(PODS_TARGET_SRCROOT)/ThingP2PSDK/CAPI $(PODS_TARGET_SRCROOT)/include/libuv/include $(PODS_TARGET_SRCROOT)/include/libsrtp/include $(PODS_TARGET_SRCROOT)/include/mbedtls/include $(PODS_TARGET_SRCROOT)/include",
    "ENABLE_BITCODE": "NO",
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64"
  },
  "user_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64"
  },
  "vendored_frameworks": [
    "Build/ThingP2PSDK.xcframework"
  ],
  "source_files": [
    "Build/ThingP2PSDK.xcframework/ios-arm64/ThingP2PSDK.framework/Headers/*"
  ]
}
